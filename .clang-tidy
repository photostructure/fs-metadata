---
Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  clang-diagnostic-format,
  performance-*,
  misc-unused-parameters,
  modernize-use-nullptr,
  cppcoreguidelines-special-member-functions,
  -bugprone-easily-swappable-parameters,
  -bugprone-exception-escape,
  -bugprone-casting-through-void,
  -bugprone-assignment-in-if-condition,
  -clang-analyzer-valist.Uninitialized

# Findings in these checks FAIL the lint job instead of merely printing.
#
# An empty WarningsAsErrors (the previous value) plus a runner that only fails on
# `error:` meant clang-tidy could never block anything -- findings just
# accumulated. These are the high-signal ownership/lifetime checks for an addon
# whose whole job is managing native resources across async boundaries. All were
# verified to have zero violations in the current tree before being enforced, and
# each name was checked against `clang-tidy --list-checks`.
#
# Deliberately NOT gated (they fire on legitimate patterns in this codebase):
#   cppcoreguidelines-owning-memory     -- Napi::AsyncWorker requires a raw `new`;
#                                          node-addon-api owns and Destroy()s it.
#   cppcoreguidelines-pro-type-member-init -- `struct statvfs`/`statfs`/btrfs ioctl
#                                          args are output params filled by syscalls.
WarningsAsErrors: >
  bugprone-use-after-move,
  bugprone-unused-raii,
  bugprone-dangling-handle,
  clang-analyzer-cplusplus.NewDeleteLeaks,
  clang-analyzer-core.NullDereference,
  cppcoreguidelines-special-member-functions

# Analyze our own headers -- and ONLY our own headers.
#
# The previous value, '^((?!/usr/include/).)*$', used a negative lookahead.
# clang-tidy matches this with llvm::Regex, which does NOT support lookaheads, so
# the pattern matched nothing and NO header was ever analyzed. Most of this
# project's logic lives in headers (shutdown.h, metadata_worker.h, raii_utils.h,
# drive_status.h, system_volume.h...), so that silently excluded the code most
# worth checking.
#
# A naive '.*/src/.*' is also wrong: it matches every path when the checkout
# happens to live under a directory named `src` (e.g. ~/src/fs-metadata), pulling
# in all of node_modules/node-addon-api. Enumerating our platform directories is
# unambiguous regardless of checkout location.
# Accept both POSIX and Windows separators. The checkout may itself live under
# an ancestor named `src`, so keep the platform-directory component rather than
# using the over-broad `.*/src/.*` form.
HeaderFilterRegex: '.*[\\/]src[\\/](common|darwin|linux|windows)[\\/].*'
FormatStyle: none
SystemHeaders: false
CheckOptions:
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: false
  - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: true
